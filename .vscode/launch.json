{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug route_planner (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/route_planner",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "windows": {
                "program": "${workspaceFolder}/route_planner.exe"
            },
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build route_planner (debug)"
        }
    ]
}
